# Copy to .env and fill in your Stripe TEST keys (https://dashboard.stripe.com/test/apikeys)
# Leave these blank and the app runs in DEMO mode (checkout is simulated, no real Stripe call).

# Server-side secret key (NEVER commit the real value). Starts with sk_test_...
STRIPE_SECRET_KEY=

# Port the API server listens on (Vite dev proxies /api here).
PORT=3001

# Public base URL of the site, used for Stripe success/cancel redirects.
PUBLIC_URL=http://localhost:5173
