# ── Supabase (catalog + admin + inventory) ──────────────────────────────────
# The macyprints schema lives in the shared Supabase project. The anon key is
# public/RLS-protected, so it's safe in the browser bundle.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Stripe (server-side, optional) ──────────────────────────────────────────
# Leave STRIPE_SECRET_KEY blank to run checkout in DEMO mode (no real payment).
# https://dashboard.stripe.com/test/apikeys  (starts with sk_test_...)
STRIPE_SECRET_KEY=
PORT=3001
PUBLIC_URL=http://localhost:5173
